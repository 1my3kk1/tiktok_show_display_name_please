{
  "manifest_version": 3,
  "name": "tiktok_show_display_name_mod",
  "version": "0.1.1",
  "description": "sử dụng \"tên hiển thị\" cho trang chủ tiktok web vì tiktok không làm. (vẫn hiện tên người dùng (nhỏ) bên cạnh)",
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["src/runtime.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/*.js"],
      "matches": ["https://www.tiktok.com/*"]
    }
  ]
}
